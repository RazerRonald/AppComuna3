rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function autenticado() {
      return request.auth != null;
    }

    function esEdil() {
      return autenticado()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.rol == 'edil';
    }

    function finalizacionNoSolicitada() {
      return (
          !resource.data.keys().hasAny(['finalizacion_solicitada'])
          || resource.data.finalizacion_solicitada == false
          || resource.data.finalizacion_solicitada == null
        )
        && (
          !resource.data.keys().hasAny(['finalizacion_estado'])
          || resource.data.finalizacion_estado == null
        );
    }

    function puedeSolicitarFinalizacion() {
      return autenticado()
        && resource.data.uid_estudiante == request.auth.uid
        && resource.data.estado == 'Expedida'
        && finalizacionNoSolicitada()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'finalizacion_solicitada',
          'finalizacion_estado',
          'fecha_solicitud_finalizacion'
        ])
        && request.resource.data.finalizacion_solicitada == true
        && request.resource.data.finalizacion_estado == 'Pendiente'
        && request.resource.data.fecha_solicitud_finalizacion == request.time;
    }

    function camposSolicitudInicial() {
      return [
        'uid_estudiante',
        'nombre_completo',
        'tipo_documento',
        'numero_documento',
        'ciudad_documento',
        'universidad',
        'carrera',
        'semestre_actual',
        'horas_a_realizar',
        'lugar_realizacion',
        'estado',
        'fecha_solicitud',
        'fecha_resolucion',
        'documento_expedido_id',
        'documento_expedido_url',
        'finalizacion_solicitada',
        'finalizacion_estado',
        'fecha_solicitud_finalizacion',
        'fecha_expedicion_finalizacion',
        'documento_finalizacion_id',
        'documento_finalizacion_url'
      ];
    }

    function stringNoVacio(valor, max) {
      return valor is string
        && valor.size() > 0
        && valor.size() <= max;
    }

    function stringOpcional(data, campo, max) {
      let valor = data.get(campo, null);
      return valor == null
        || (valor is string && valor.size() <= max);
    }

    function camposCrearNoticia() {
      return [
        'titulo',
        'cuerpo',
        'fechaPublicacion',
        'autorId',
        'media_drive_id',
        'media_tipo',
        'media_url',
        'media_embed_url',
        'media_view_url',
        'media_mime',
        'media_nombre',
        'media_folder_id'
      ];
    }

    function camposNoticia() {
      return [
        'titulo',
        'cuerpo',
        'fechaPublicacion',
        'autorId',
        'media_drive_id',
        'media_tipo',
        'media_url',
        'media_embed_url',
        'media_view_url',
        'media_mime',
        'media_nombre',
        'media_folder_id',
        'fechaActualizacion',
        'portadaUrl'
      ];
    }

    function camposEditablesNoticia() {
      return [
        'titulo',
        'cuerpo',
        'fechaActualizacion',
        'media_drive_id',
        'media_tipo',
        'media_url',
        'media_embed_url',
        'media_view_url',
        'media_mime',
        'media_nombre',
        'media_folder_id'
      ];
    }

    function textoNoticiaValido(data) {
      return stringNoVacio(data.titulo, 200)
        && stringNoVacio(data.cuerpo, 12000);
    }

    function mediaNoticiaVacia(data) {
      return data.media_drive_id == null
        && data.media_tipo == null
        && data.media_url == null
        && data.media_embed_url == null
        && data.media_view_url == null
        && data.media_mime == null
        && data.media_nombre == null
        && data.media_folder_id == null;
    }

    function mediaNoticiaActualValida(data) {
      return (data.media_tipo == 'imagen' || data.media_tipo == 'video')
        && stringNoVacio(data.media_drive_id, 256)
        && stringNoVacio(data.media_url, 1200)
        && stringNoVacio(data.media_embed_url, 1200)
        && stringOpcional(data, 'media_view_url', 1200)
        && stringNoVacio(data.media_mime, 160)
        && stringNoVacio(data.media_nombre, 220)
        && stringNoVacio(data.media_folder_id, 256);
    }

    function mediaNoticiaValida(data) {
      return (
          data.keys().hasAll([
            'media_drive_id',
            'media_tipo',
            'media_url',
            'media_embed_url',
            'media_view_url',
            'media_mime',
            'media_nombre',
            'media_folder_id'
          ])
          && (mediaNoticiaVacia(data) || mediaNoticiaActualValida(data))
        )
        || (
          !data.keys().hasAny(['media_tipo'])
          && stringOpcional(data, 'portadaUrl', 1200)
        );
    }

    function noticiaValida(data) {
      return data.keys().hasOnly(camposNoticia())
        && textoNoticiaValido(data)
        && data.autorId is string
        && data.fechaPublicacion is timestamp
        && mediaNoticiaValida(data)
        && stringOpcional(data, 'portadaUrl', 1200);
    }

    function camposCrearEvento() {
      return [
        'titulo',
        'descripcion',
        'fecha',
        'fecha_fin',
        'lugar',
        'autorId',
        'creadoEn'
      ];
    }

    function camposEvento() {
      return [
        'titulo',
        'descripcion',
        'fecha',
        'fecha_fin',
        'lugar',
        'autorId',
        'creadoEn',
        'actualizadoEn'
      ];
    }

    function camposEditablesEvento() {
      return [
        'titulo',
        'descripcion',
        'fecha',
        'fecha_fin',
        'lugar',
        'actualizadoEn'
      ];
    }

    function eventoValido(data) {
      return data.keys().hasOnly(camposEvento())
        && stringNoVacio(data.titulo, 160)
        && stringNoVacio(data.descripcion, 4000)
        && stringNoVacio(data.lugar, 240)
        && data.autorId is string
        && data.fecha is timestamp
        && data.fecha_fin is timestamp
        && data.fecha_fin > data.fecha;
    }

    function camposUsuario() {
      return [
        'uid',
        'email',
        'nombre',
        'rol',
        'creadoEn',
        'creadoPor'
      ];
    }

    function camposBaseUsuario() {
      return [
        'uid',
        'email',
        'nombre',
        'rol',
        'creadoEn'
      ];
    }

    function usuarioEstudianteValido(data, userId) {
      return data.keys().hasOnly(camposUsuario())
        && data.keys().hasAll(camposBaseUsuario())
        && data.uid == userId
        && stringNoVacio(data.email, 180)
        && stringNoVacio(data.nombre, 120)
        && data.rol == 'estudiante'
        && data.creadoEn == request.time;
    }

    match /noticias/{noticiaId} {
      allow read: if true;

      allow create: if esEdil()
        && request.resource.data.keys().hasOnly(camposCrearNoticia())
        && request.resource.data.keys().hasAll(camposCrearNoticia())
        && textoNoticiaValido(request.resource.data)
        && request.resource.data.autorId == request.auth.uid
        && request.resource.data.fechaPublicacion == request.time
        && mediaNoticiaVacia(request.resource.data);

      allow update: if esEdil()
        && noticiaValida(request.resource.data)
        && request.resource.data.autorId == resource.data.autorId
        && request.resource.data.fechaPublicacion == resource.data.fechaPublicacion
        && request.resource.data.fechaActualizacion == request.time
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(camposEditablesNoticia());

      allow delete: if esEdil();
    }

    match /eventos/{eventoId} {
      allow read: if true;

      allow create: if esEdil()
        && request.resource.data.keys().hasOnly(camposCrearEvento())
        && request.resource.data.keys().hasAll(camposCrearEvento())
        && eventoValido(request.resource.data)
        && request.resource.data.autorId == request.auth.uid
        && request.resource.data.creadoEn == request.time;

      allow update: if esEdil()
        && eventoValido(request.resource.data)
        && request.resource.data.autorId == resource.data.autorId
        && request.resource.data.creadoEn == resource.data.creadoEn
        && request.resource.data.actualizadoEn == request.time
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(camposEditablesEvento());

      allow delete: if esEdil();
    }

    match /info_carta_inicial/{solicitudId} {
      allow get, list: if autenticado()
        && (esEdil() || resource.data.uid_estudiante == request.auth.uid);

      allow create: if autenticado()
        && request.resource.data.keys().hasOnly(camposSolicitudInicial())
        && request.resource.data.keys().hasAll(camposSolicitudInicial())
        && request.resource.data.uid_estudiante == request.auth.uid
        && request.resource.data.uid_estudiante is string
        && request.resource.data.estado == 'Pendiente'
        && request.resource.data.fecha_solicitud == request.time
        && request.resource.data.fecha_resolucion == null
        && request.resource.data.nombre_completo is string
        && request.resource.data.tipo_documento is string
        && request.resource.data.numero_documento is string
        && request.resource.data.ciudad_documento is string
        && request.resource.data.universidad is string
        && request.resource.data.carrera is string
        && request.resource.data.semestre_actual is int
        && request.resource.data.semestre_actual > 0
        && request.resource.data.horas_a_realizar is number
        && request.resource.data.horas_a_realizar > 0
        && request.resource.data.lugar_realizacion is string
        && request.resource.data.documento_expedido_id == null
        && request.resource.data.documento_expedido_url == null
        && request.resource.data.finalizacion_solicitada == false
        && request.resource.data.finalizacion_estado == null
        && request.resource.data.fecha_solicitud_finalizacion == null
        && request.resource.data.fecha_expedicion_finalizacion == null
        && request.resource.data.documento_finalizacion_id == null
        && request.resource.data.documento_finalizacion_url == null;

      allow update: if esEdil() || puedeSolicitarFinalizacion();
      allow delete: if esEdil();
    }

    match /info_carta_documentos/{solicitudId} {
      allow read, write: if esEdil();
    }

    match /users/{userId} {
      allow read: if autenticado()
        && (request.auth.uid == userId || esEdil());

      allow create: if autenticado()
        && usuarioEstudianteValido(request.resource.data, userId)
        && (
          (
            request.auth.uid == userId
            && !request.resource.data.keys().hasAny(['creadoPor'])
          )
          || (
            esEdil()
            && request.auth.uid != userId
            && request.resource.data.creadoPor == request.auth.uid
          )
        );

      allow update, delete: if esEdil();
    }
  }
}
