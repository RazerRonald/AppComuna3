# Vercel / API proxy de imagenes de noticias
# Configurar en Vercel > Project Settings > Environment Variables.
# Esta key se usa desde servidor; si la restringes por HTTP referrer, el proxy puede fallar.
FIREBASE_PROJECT_ID=jal3-fd8a2
FIREBASE_WEB_API_KEY=tu_api_key_web_de_firebase

# API administrativa de usuarios (solo servidor / Vercel).
# Puedes usar FIREBASE_SERVICE_ACCOUNT con el JSON completo de la cuenta
# de servicio, o GOOGLE_CLIENT_EMAIL + GOOGLE_PRIVATE_KEY.
FIREBASE_SERVICE_ACCOUNT={"client_email":"firebase-adminsdk@tu-proyecto.iam.gserviceaccount.com","private_key":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n"}
# GOOGLE_CLIENT_EMAIL=firebase-adminsdk@tu-proyecto.iam.gserviceaccount.com
# GOOGLE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n
